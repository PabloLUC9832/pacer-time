model EventModalityGenderCategory {
  id         String   @id @default(uuid())
  // Relación con Event
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId    String   @map("event_id")
  // Relación con Modality
  modality   Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  modalityId String   @map("modality_id")
  // Relación con Gender
  gender     Gender   @relation(fields: [genderId], references: [id], onDelete: Cascade)
  genderId   String   @map("gender_id")
  // Relación con Category
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([eventId, modalityId, genderId, categoryId], name: "unique_event_modality_gender_category")
  @@index([eventId, modalityId, genderId, categoryId])
  @@map("events_modalities_genders_categories")
}
